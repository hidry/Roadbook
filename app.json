{
  "expo": {
    "name": "Roadbook",
    "slug": "roadbook",
    "owner": "hidry",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "roadbook",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "bundleIdentifier": "de.hidry.roadbook",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Roadbook liest die GPS- und Zeit-Metadaten der ausgewählten Fotos, um daraus deine Reiseroute vorzuschlagen.",
        "NSLocationWhenInUseUsageDescription": "Wird für die Kartenansicht deiner Reise verwendet."
      }
    },
    "android": {
      "package": "de.hidry.roadbook",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Roadbook braucht Zugriff auf deine Fotos, um aus ihren GPS-/Zeit-Metadaten eine Route vorzuschlagen."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Roadbook liest die Metadaten deiner Fotos (Ort, Zeit), um Reisestopps zu erkennen.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "60b0e3b8-004c-4afe-b297-e3332ea16968"
      }
    }
  }
}
