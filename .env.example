# ── Roadbook environment ──────────────────────────────────────────────────────
# Copy to `.env` for local dev. EXPO_PUBLIC_* values are bundled into the app
# (client-side, not secret). The R2 secrets are SERVER-ONLY (Edge Function) and
# must never be shipped in the app — see supabase/functions/r2-presign.

# ── Supabase (client) ─────────────────────────────────────────────────────────
# Local dev via `supabase start` prints these. Cloud: Project Settings → API.
# Region for production MUST be eu-central-1 / Frankfurt (README §7).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ── Map tiles (client) ────────────────────────────────────────────────────────
# MapLibre style URL. Production: self-hosted Protomaps/PMTiles on R2 (README §3).
# NEVER use tile.openstreetmap.org (commercial + offline forbidden). Leave empty
# to render the map without a basemap (markers/route line still work).
EXPO_PUBLIC_MAP_STYLE_URL=

# Base URL of the deployed r2-presign Edge Function (photo uploads).
# Local: http://127.0.0.1:54321/functions/v1/r2-presign
EXPO_PUBLIC_R2_PRESIGN_URL=http://127.0.0.1:54321/functions/v1/r2-presign

# ── R2 (SERVER-ONLY — Edge Function secrets, never EXPO_PUBLIC_*) ──────────────
# Set via `supabase secrets set` / dashboard, not in the app bundle.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=roadbook-photos
# Public base URL the app uses to read uploaded photos (R2 public bucket / custom domain).
R2_PUBLIC_BASE_URL=

# ── RLS isolation test (scripts/rls-test.ts) ──────────────────────────────────
# Uses the local Supabase service role key to create two users, then asserts
# tenant isolation. Service role bypasses RLS — LOCAL/CI ONLY, never in the app.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
SUPABASE_ANON_KEY=your-local-anon-key
